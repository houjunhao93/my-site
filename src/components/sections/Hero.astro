---
import ParticleBg from "../ui/ParticleBg";
import { personalInfo } from "../../lib/config";

const { brandTags, tagline } = personalInfo;
---

<section id="hero" class="relative min-h-screen flex items-center justify-center overflow-hidden">
  <ParticleBg client:visible />

  <div class="relative z-10 text-center px-6 max-w-3xl">
    <!-- Brand Tags -->
    <div class="flex flex-wrap justify-center gap-3 md:gap-4 mb-6">
      {brandTags.map((tag) => (
        <span
          key={tag}
          class="hero-tag inline-block text-2xl md:text-4xl lg:text-5xl font-bold tracking-tight"
          style="color: var(--accent); text-shadow: 0 0 30px var(--accent-glow);"
        >
          {tag}
        </span>
      ))}
    </div>

    <!-- Tagline -->
    <p class="hero-tagline mt-4 text-lg md:text-xl lg:text-2xl" style="color: var(--text-secondary); font-weight: 400;">
      {tagline}
    </p>

    <!-- Scroll indicator -->
    <div class="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2">
      <span style="font-size: 0.75rem; color: var(--text-secondary); letter-spacing: 0.1em;">
        SCROLL
      </span>
      <div class="w-6 h-10 rounded-full border-2" style="border-color: var(--text-secondary);">
        <div class="w-1.5 h-3 rounded-full mx-auto mt-2 animate-bounce" style="background: var(--accent);" />
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";

  const hero = document.getElementById("hero");
  if (hero) {
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          const tags = hero.querySelectorAll(".hero-tag");
          const tagline = hero.querySelector(".hero-tagline");

          const tl = gsap.timeline({ defaults: { ease: "power3.out" } });

          tl.fromTo(
            tags,
            { opacity: 0, y: 40, scale: 0.9 },
            { opacity: 1, y: 0, scale: 1, duration: 0.8, stagger: 0.2 }
          )
            .fromTo(
              tagline,
              { opacity: 0, y: 20 },
              { opacity: 1, y: 0, duration: 0.6 },
              "-=0.3"
            );

          observer.disconnect();
        }
      },
      { threshold: 0.3 }
    );
    observer.observe(hero);
  }
</script>
