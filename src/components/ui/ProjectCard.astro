---
import type { Project } from "../../lib/types";

interface Props {
  project: Project;
}

const { project } = Astro.props;
---

<div
  class="project-card card p-4 cursor-pointer relative overflow-hidden"
  data-project-id={project.id}
  style="transition: all 0.3s ease;"
>
  <!-- Screenshot Placeholder -->
  <div
    style="
      width: 100%;
      height: 160px;
      border-radius: 0.75rem;
      margin-bottom: 1rem;
      background: var(--accent-glow);
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      position: relative;
    "
  >
    <span style="color: var(--accent); font-size: 3rem; opacity: 0.4;">
      {project.title.charAt(0)}
    </span>
    <span style="
      position: absolute;
      bottom: 0.5rem;
      right: 0.75rem;
      font-size: 0.7rem;
      color: var(--text-secondary);
      opacity: 0.5;
    ">
      Screenshot
    </span>
  </div>

  <!-- Title -->
  <h3 class="font-semibold text-base mb-2" style="color: var(--text-primary);">
    {project.title}
  </h3>

  <!-- Tags -->
  <div class="flex flex-wrap gap-1.5 mb-3">
    {project.tags.slice(0, 3).map((tag) => (
      <span class="tag-chip" style="font-size: 0.65rem;">{tag}</span>
    ))}
    {project.tags.length > 3 && (
      <span class="tag-chip" style="font-size: 0.65rem; opacity: 0.7;">+{project.tags.length - 3}</span>
    )}
  </div>

  <!-- Summary -->
  <p style="color: var(--text-secondary); font-size: 0.85rem; line-height: 1.5;">
    {project.summary}
  </p>

  <!-- Status badge -->
  {project.status === "wip" && (
    <span style="
      position: absolute;
      top: 0.75rem;
      right: 0.75rem;
      font-size: 0.6rem;
      padding: 0.15rem 0.5rem;
      border-radius: 9999px;
      background: rgba(251, 191, 36, 0.2);
      color: #f59e0b;
      border: 1px solid #f59e0b;
    ">
      WIP
    </span>
  )}
</div>
